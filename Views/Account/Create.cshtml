@model Document_Management.Models.Account

@{
    ViewData["Title"] = "Register";
}

<link href="~/css/user-create-from-style.css" rel="stylesheet" />

<div class="create-form-wrapper">

    <div class="d-flex align-items-start justify-content-between mb-3">
        <div>
            <h4 class="mb-0">Create User</h4>
            <p class="text-muted mb-0" style="font-size:0.85rem;">Fill in the details below to register a new employee.</p>
        </div>
        <a asp-action="Index" class="btn btn-primary btn-sm">&#8592; Back to List</a>
    </div>

    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()

        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <!-- Section 1: Employee Info -->
        <div class="form-section">
            <div class="form-section-header">
                <span>Employee Information</span>
            </div>
            <div class="form-section-body">
                <div class="field-row field-row-3 mb-3">
                    <div>
                        <label asp-for="EmployeeNumber" class="form-label small fw-semibold"></label>
                        <input asp-for="EmployeeNumber" type="number" value="" class="form-control form-control-sm" placeholder="Employee #" />
                        <span asp-validation-for="EmployeeNumber" class="text-danger small"></span>
                    </div>
                    <div>
                        <label asp-for="FirstName" class="form-label small fw-semibold"></label>
                        <input asp-for="FirstName" class="form-control form-control-sm" placeholder="First name" />
                        <span asp-validation-for="FirstName" class="text-danger small"></span>
                    </div>
                    <div>
                        <label asp-for="LastName" class="form-label small fw-semibold"></label>
                        <input asp-for="LastName" class="form-control form-control-sm" placeholder="Last name" />
                        <span asp-validation-for="LastName" class="text-danger small"></span>
                    </div>
                </div>
                <div class="field-row field-row-2 mb-3">
                    <div>
                        <label asp-for="Department" class="form-label small fw-semibold"></label>
                        <select asp-for="Department" asp-items="Model.Departments" class="form-select form-select-sm js-select2">
                            <option value="" selected disabled>-- Select department --</option>
                        </select>
                        <span asp-validation-for="Department" class="text-danger small"></span>
                    </div>
                    <div>
                        <label asp-for="Role" class="form-label small fw-semibold"></label>
                        <select asp-for="Role" class="form-select form-select-sm">
                            <option value="" selected disabled>-- Select user role --</option>
                            @foreach (var role in Enum.GetValues(typeof(Roles)))
                            {
                                <option value="@role">@Enum.GetName(typeof(Roles), role)</option>
                            }
                        </select>
                        <span asp-validation-for="Role" class="text-danger small"></span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Section 2: Credentials -->
        <div class="form-section">
            <div class="form-section-header">
                <span>Account Credentials</span>
            </div>
            <div class="form-section-body">
                <div class="field-row field-row-3 mb-3">
                    <div>
                        <label asp-for="Username" class="form-label small fw-semibold"></label>
                        <input asp-for="Username" class="form-control form-control-sm" placeholder="Username" />
                        <span asp-validation-for="Username" class="text-danger small"></span>
                    </div>
                    <div>
                        <label asp-for="Password" class="form-label small fw-semibold"></label>
                        <input asp-for="Password" type="password" class="form-control form-control-sm" placeholder="Password" />
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>
                    <div>
                        <label asp-for="ConfirmPassword" class="form-label small fw-semibold"></label>
                        <input asp-for="ConfirmPassword" type="password" class="form-control form-control-sm" placeholder="Confirm password" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Section 3: Access Permissions -->
        <div class="form-section">
            <div class="form-section-header">
                <span>Access Permissions</span>
            </div>
            <div class="form-section-body">
                <div class="check-subsection-label">Departments</div>
                <div class="check-grid">
                    @foreach (var department in Model.Departments!)
                    {
                        <label class="check-pill">
                            <input type="checkbox" name="AccessDepartments" value="@department.Value" />
                            @department.Text
                        </label>
                    }
                </div>
                <div class="check-subsection-label">Companies</div>
                <div class="check-grid">
                    @foreach (var company in Model.Companies!)
                    {
                        <label class="check-pill">
                            <input type="checkbox" name="AccessCompanies" value="@company.Value" />
                            @company.Text
                        </label>
                    }
                </div>
            </div>
        </div>

        <!-- Actions -->
        <div class="d-flex justify-content-end gap-2 pt-1">
            <input type="submit" value="Save" class="btn btn-secondary btn-sm px-4" />
        </div>

    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
